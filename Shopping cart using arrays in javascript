<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Shopping Cart (Array)</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f4f4;
            text-align: center;
        }

        .container {
            width: 350px;
            margin: 50px auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px gray;
        }

        input {
            padding: 8px;
            margin: 5px;
            width: 130px;
        }

        button {
            padding: 8px 12px;
            margin: 5px;
            background: green;
            color: white;
            border: none;
            cursor: pointer;
            border-radius: 5px;
        }

        button:hover {
            background: darkgreen;
        }

        ul {
            list-style: none;
            padding: 0;
        }

        li {
            background: #eee;
            margin: 5px;
            padding: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 5px;
        }

        .remove {
            background: red;
        }

        .remove:hover {
            background: darkred;
        }

        .total {
            font-weight: bold;
            margin-top: 10px;
        }
    </style>
</head>

<body>

<div class="container">
    <h2>🛒 Shopping Cart</h2>

    <input type="text" id="itemName" placeholder="Item Name">
    <input type="number" id="itemPrice" placeholder="Price" min="1">

    <br>

    <button id="addBtn">Add Item</button>
    <button id="clearBtn">Clear Cart</button>

    <ul id="cartList"></ul>

    <div class="total">Total: ₹ <span id="totalPrice">0</span></div>
</div>

<script>
    let cart = [];

    const itemName = document.getElementById("itemName");
    const itemPrice = document.getElementById("itemPrice");
    const cartList = document.getElementById("cartList");
    const totalPrice = document.getElementById("totalPrice");

    document.getElementById("addBtn").addEventListener("click", addItem);
    document.getElementById("clearBtn").addEventListener("click", clearCart);

    // Add using Enter key
    itemPrice.addEventListener("keypress", function(e) {
        if (e.key === "Enter") {
            addItem();
        }
    });

    function addItem() {
        let name = itemName.value.trim();
        let price = parseFloat(itemPrice.value);

        if (name === "" || isNaN(price) || price <= 0) {
            alert("Enter valid item name and price (> 0)");
            return;
        }

        cart.push({ name: name, price: price });
        displayCart();

        itemName.value = "";
        itemPrice.value = "";
        itemName.focus();
    }

    function displayCart() {
        cartList.innerHTML = "";
        let total = 0;

        cart.forEach((item, index) => {
            total += item.price;

            let li = document.createElement("li");

            let text = document.createElement("span");
            text.textContent = `${item.name} - ₹${item.price.toFixed(2)}`;

            let btn = document.createElement("button");
            btn.textContent = "X";
            btn.className = "remove";
            btn.onclick = () => removeItem(index);

            li.appendChild(text);
            li.appendChild(btn);
            cartList.appendChild(li);
        });

        totalPrice.textContent = total.toFixed(2);
    }

    function removeItem(index) {
        cart.splice(index, 1);
        displayCart();
    }

    function clearCart() {
        cart = [];
        displayCart();
    }
</script>

</body>
</html>
