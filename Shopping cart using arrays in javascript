class Item {
    String name;
    double price;
    int quantity;

    public Item(String name, double price, int quantity) {
        this.name = name;
        this.price = price;
        this.quantity = quantity;
    }
}

public class ShoppingCart {
    private Item[] cart;
    private int itemCount;
    private double totalBill;

    public ShoppingCart(int capacity) {
        cart = new Item[capacity]; // Initialize array with fixed capacity
        itemCount = 0;
        totalBill = 0;
    }

    public void addItem(String name, double price, int qty) {
        if (itemCount < cart.length) {
            cart[itemCount] = new Item(name, price, qty);
            totalBill += (price * qty);
            itemCount++;
            System.out.println(name + " added to cart.");
        } else {
            System.out.println("Error: Shopping cart is full!");
        }
    }

    public void displayCart() {
        System.out.println("\n--- Your Shopping Cart ---");
        for (int i = 0; i < itemCount; i++) {
            System.out.println(cart[i].name + " | Price: $" + cart[i].price + " | Qty: " + cart[i].quantity);
        }
        System.out.println("Total Amount: $" + totalBill);
    }

    public static void main(String[] args) {
        ShoppingCart myCart = new ShoppingCart(5);
        myCart.addItem("Laptop", 1200.00, 1);
        myCart.addItem("Mouse", 25.50, 2);
        myCart.displayCart();
    }
}
